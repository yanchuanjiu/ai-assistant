# Feishu / 飞书
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx
FEISHU_VERIFICATION_TOKEN=xxxx
FEISHU_ENCRYPT_KEY=
FEISHU_WIKI_SPACE_ID=xxxx        # python -m tools.list_feishu_spaces

# 火山云 Ark（主力模型）
VOLCENGINE_API_KEY=xxxx
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=doubao-pro-32k   # 或填 endpoint ID: ep-xxx

# Anthropic（Claude 兜底）
ANTHROPIC_API_KEY=sk-ant-xxxx

# Email / 163 IMAP
EMAIL_ADDRESS=xxxx@163.com
EMAIL_AUTH_CODE=xxxx
IMAP_HOST=imap.163.com
IMAP_PORT=993

# DingTalk / 钉钉
DINGTALK_APP_ID=xxxx
DINGTALK_CLIENT_ID=xxxx
DINGTALK_CLIENT_SECRET=xxxx
DINGTALK_DOCS_SPACE_ID=xxxx
DINGTALK_AGENT_ID=xxxx

# Storage (待定)
STORAGE_PROVIDER=local
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
VOLCENGINE_BUCKET=
VOLCENGINE_ENDPOINT=

# App
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
